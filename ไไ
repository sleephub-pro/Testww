-- V1 CODE (เพิ่มตรวจ _G.AutoFarmEnabled และ _G.BossHunting)
-- =============================================
local function RunV1()
    print("✅ เริ่มรัน V1")
    local root = player.Character:WaitForChild("HumanoidRootPart")
    local floatConnection = nil
   
    local function StartFloating()
        if floatConnection then return end
        local hum = player.Character:FindFirstChild("Humanoid")
        if hum then hum.PlatformStand = true end
       
        floatConnection = RunService.Heartbeat:Connect(function()
            if root and root.Parent and not _G.BossHunting and _G.AutoFarmEnabled then
                root.Velocity = Vector3.new(0,0,0)
                root.AssemblyLinearVelocity = Vector3.new(0,0,0)
                root.AssemblyAngularVelocity = Vector3.new(0,0,0)
                local p = root.Position
                root.CFrame = CFrame.new(p.X, p.Y, p.Z) * root.CFrame.Rotation
            end
        end)
    end
   
    local function TeleportAndFloat(cf)
        if _G.BossHunting or not _G.AutoFarmEnabled then return end
        root.CFrame = cf + Vector3.new(0, 12, 0)
        task.wait(0.2)
        StartFloating()
    end
   
    local function RemoveIslands()
        local islands = {"JudgementIsland","LawlessIsland","NinjaIsland","SoulDominionIsland","TowerIsland","AcademyIsland","HollowIsland","ShinjukuIsland","BossIsland","DesertIsland","JungleIsland","SailorIsland","SlimeIsland","SnowIsland","StarterIsland"}
        for _, v in ipairs(islands) do
            if workspace:FindFirstChild(v) then workspace[v]:Destroy() end
        end
    end
   
    local function BuyAllMerchantItems()
        local merchant = ReplicatedStorage.Remotes.MerchantRemotes.PurchaseMerchantItem
        local items = {{"Dungeon Key",999},{"Boss Key",999},{"Haki Color Reroll",999},{"Race Reroll",999},{"Rush Key",999},{"Passive Shard",999},{"Trait Reroll",999},{"Clan Reroll",999}}
        for _, item in ipairs(items) do
            pcall(function() merchant:InvokeServer(unpack(item)) end)
            task.wait(0.12)
        end
    end
   
    local portals = {
        {name = "Ninja", pos = CFrame.new(-1875.734375, 8.514030, -732.247070)},
        {name = "Lawless", pos = CFrame.new(58.674271, 0.578746, 1825.821777)},
        {name = "Judgement", pos = CFrame.new(-1268.837280, 1.163063, -1184.665771)},
        {name = "Academy", pos = CFrame.new(1059.421997, 1.463216, 1271.781860)},
        {name = "Slime", pos = CFrame.new(-1121.603027, 13.918226, 371.301483)},
        {name = "Shinjuku", pos = CFrame.new(-7.679499, 1.898112, -1842.801514)},
    }
   
    while _G.AutoFarmVersion == "V1" do
        if _G.AutoFarmEnabled and not _G.BossHunting then
            EquipSelectedWeapon()
            RemoveIslands()
            BuyAllMerchantItems()
           
            for _, portal in ipairs(portals) do
                if not _G.AutoFarmEnabled or _G.BossHunting then break end
                EquipSelectedWeapon()
                RemoveIslands()
                ReplicatedStorage.Remotes.TeleportToPortal:FireServer(portal.name)
                task.wait(0.2)
                TeleportAndFloat(portal.pos)
                task.wait(0.2)
                UseSelectedSkill()
                task.wait(0.1)
            end
            print("✅ ครบ 1 รอบ V1 | รอรอบใหม่")
        end
        task.wait(0.5)
    end
end

-- =============================================
-- V2 CODE (เพิ่มตรวจ _G.AutoFarmEnabled และ _G.BossHunting)
-- =============================================
local function RunV2()
    print("✅ เริ่มรัน V2")
   
    local maps = {"JudgementIsland","LawlessIsland","NinjaIsland","SoulDominionIsland","TowerIsland","AcademyIsland","HollowIsland","ShinjukuIsland","BossIsland","DesertIsland","JungleIsland","SailorIsland","SlimeIsland","SnowIsland","StarterIsland"}
    for _,v in pairs(maps) do
        if workspace:FindFirstChild(v) then workspace[v]:Destroy() end
    end
   
    task.spawn(function()
        while _G.AutoFarmVersion == "V2" do
            if _G.AutoFarmEnabled and not _G.BossHunting then
                local buyList = {{"Dungeon Key",999},{"Boss Key",999},{"Haki Color Reroll",999},{"Race Reroll",999},{"Rush Key",999},{"Passive Shard",999},{"Trait Reroll",999},{"Clan Reroll",999}}
                for _,v in pairs(buyList) do
                    pcall(function() ReplicatedStorage.Remotes.MerchantRemotes.PurchaseMerchantItem:InvokeServer(v[1], v[2]) end)
                    task.wait(0.2)
                end
            end
            task.wait(1)
        end
    end)
   
    local data = {
        {"Ninja","QuestNPC18",Vector3.new(-1875.734375,18.51403,-732.24707)},
        {"Lawless","QuestNPC19",Vector3.new(58.674271,10.578746,1825.821777)},
        {"Judgement","QuestNPC16",Vector3.new(-1268.83728,11.163063,-1184.665771)},
        {"Academy","QuestNPC15",Vector3.new(1059.421997,11.463216,1271.78186)},
        {"Slime","QuestNPC14",Vector3.new(-1121.603027,23.918226,371.301483)},
    }
    local shinjuku1 = Vector3.new(-7.679499,11.898112,-1842.801514)
    local shinjuku2 = Vector3.new(658.236511,11.883463,-1688.614136)
   
    local floatBV
    local function startFloat()
        local char = player.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        if hrp then
            if floatBV then floatBV:Destroy() end
            floatBV = Instance.new("BodyVelocity")
            floatBV.MaxForce = Vector3.new(1e9,1e9,1e9)
            floatBV.Velocity = Vector3.new(0,0,0)
            floatBV.Parent = hrp
        end
    end
    local function tp(pos)
        if _G.BossHunting or not _G.AutoFarmEnabled then return end
        local char = player.Character
        if char and char:FindFirstChild("HumanoidRootPart") then
            char:PivotTo(CFrame.new(pos))
            startFloat()
        end
    end
    local function island(n)
        if _G.BossHunting or not _G.AutoFarmEnabled then return end
        ReplicatedStorage.Remotes.TeleportToPortal:FireServer(n)
    end
    local function quest(q)
        if _G.BossHunting or not _G.AutoFarmEnabled then return end
        ReplicatedStorage.RemoteEvents.QuestAccept:FireServer(q)
    end
   
    while _G.AutoFarmVersion == "V2" do
        if _G.AutoFarmEnabled and not _G.BossHunting then
            for _,v in pairs(data) do
                if not _G.AutoFarmEnabled or _G.BossHunting then break end
                quest(v[2]); task.wait(0.25)
                island(v[1]); task.wait(0.7)
                tp(v[3])
                EquipSelectedWeapon(); task.wait(0.25)
                UseSelectedSkill(); task.wait(1.2)
            end
            -- Shinjuku
            if _G.AutoFarmEnabled and not _G.BossHunting then
                quest("QuestNPC13"); task.wait(0.25); island("Shinjuku"); task.wait(0.7); tp(shinjuku1); EquipSelectedWeapon(); task.wait(0.25); UseSelectedSkill(); task.wait(1.2)
                quest("QuestNPC12"); task.wait(0.25); island("Shinjuku"); task.wait(0.7); tp(shinjuku2); EquipSelectedWeapon(); task.wait(0.25); UseSelectedSkill(); task.wait(1.2)
            end
        end
        task.wait(0.5)
    end
end

