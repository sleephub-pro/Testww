-- ระบบล่าบอส (รองรับ _G.BossList)
-- =============================================
local bossesConfig = {
    {boss="AizenBoss",               island="HollowIsland"},
    {boss="GojoBoss",                island="Shibuya"},
    {boss="JinwooBoss",              island="Sailor"},
    {boss="StrongestShinobiBoss",    island="Ninja"},
    {boss="SukunaBoss",              island="Shibuya"},
    {boss="YujiBoss",                island="Shibuya"},
    {boss="YamatoBoss",              island="Judgement"},
}

local currentFloatBV = nil
local function ClearFloat()
    if currentFloatBV then currentFloatBV:Destroy(); currentFloatBV = nil end
    local hum = player.Character and player.Character:FindFirstChild("Humanoid")
    if hum then hum.PlatformStand = false end
end

local function FloatToBoss(bossPos)
    ClearFloat()
    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    root.CFrame = CFrame.new(bossPos.X, bossPos.Y + 8, bossPos.Z)
    local hum = char:FindFirstChild("Humanoid")
    if hum then hum.PlatformStand = true end
    currentFloatBV = Instance.new("BodyVelocity")
    currentFloatBV.MaxForce = Vector3.new(1e5, 1e5, 1e5)
    currentFloatBV.Velocity = Vector3.new(0, 0, 0)
    currentFloatBV.Parent = root
end

local function IsBossAllowed(bossName)
    -- ถ้า BossList ว่าง = ตีทุกบอส
    if not _G.BossList or #_G.BossList == 0 then return true end
    for _, v in ipairs(_G.BossList) do
        if v == bossName then return true end
    end
    return false
end

local function CheckAndHuntBoss()
    if not _G.BossMode then return end
    if _G.BossHunting then return end
    local npcs = workspace:FindFirstChild("NPCs")
    if not npcs then return end
    for _, cfg in ipairs(bossesConfig) do
        -- เช็ค BossList
        if not IsBossAllowed(cfg.boss) then continue end

        local boss = npcs:FindFirstChild(cfg.boss)
        if boss and boss:FindFirstChild("HumanoidRootPart") then
            _G.BossHunting = true
            print("🔥 พบบอส:", cfg.boss)
            pcall(RemTeleport.FireServer, RemTeleport, cfg.island)
            task.wait(0.3)
            local b2 = npcs:FindFirstChild(cfg.boss)
            if b2 and b2:FindFirstChild("HumanoidRootPart") then
                FloatToBoss(b2.HumanoidRootPart.Position)
                EquipSelectedWeapon()
                task.wait(0.15)
                BurstSkill(15, 0.05)
            end
            print("✅ ล่าบอสเสร็จ:", cfg.boss)
            _G.BossHunting = false
            ClearFloat()
            return
        end
    end
end

task.spawn(function()
    while true do
        CheckAndHuntBoss()
        task.wait(0.1)
    end
end)

