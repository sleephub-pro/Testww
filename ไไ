    local ramConnections = {}
    local function ApplyLowRAM()
        for _, v in ipairs(game:GetService("Lighting"):GetChildren()) do
            pcall(function() v.Enabled = false end)
        end
        pcall(function() settings().Rendering.QualityLevel = Enum.QualityLevel.Level01 end)
        pcall(function()
            game:GetService("Lighting").GlobalShadows = false
            game:GetService("Lighting").FogEnd = 9e9
        end)
        local conn = workspace.DescendantAdded:Connect(function(d)
            if d:IsA("Decal") or d:IsA("Texture") then pcall(function() d:Destroy() end) end
        end)
        table.insert(ramConnections, conn)
        for _, v in ipairs(workspace:GetDescendants()) do
            if v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Beam") then
                pcall(function() v.Enabled = false end)
            end
        end
    end
    local function DisableLowRAM()
        for _, c in ipairs(ramConnections) do pcall(function() c:Disconnect() end) end
        ramConnections = {}
        pcall(function() settings().Rendering.QualityLevel = Enum.QualityLevel.Automatic end)
        pcall(function() game:GetService("Lighting").GlobalShadows = true end)
        for _, v in ipairs(game:GetService("Lighting"):GetChildren()) do pcall(function() v.Enabled = true end) end
        for _, v in ipairs(workspace:GetDescendants()) do
            if v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Beam") then pcall(function() v.Enabled = true end) end
        end
    end
