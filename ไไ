local function EquipSelectedWeapon()
    local char = player.Character
    if not char then return end
    local tool = player.Backpack:FindFirstChild(weaponName)
    if tool and not char:FindFirstChild(weaponName) then
        char.Humanoid:EquipTool(tool)
    end
end

local function UseSelectedSkill()
    pcall(RemAbility.FireServer, RemAbility, skillNumber)
end

local function BurstSkill(times, delay)
    delay = delay or 0.05
    for i = 1, (times or 3) do
        UseSelectedSkill()
        if i < times then task.wait(delay) end
    end
end

-- =============================================
-- Anti-Disconnect
-- =============================================
local function StartAntiDisconnect()
    if not _G.AntiDisconnect then return end
    task.spawn(function()
        while true do
            task.wait(19 * 60)
            pcall(function()
                local char = player.Character
                if char then
                    if char:FindFirstChild("Humanoid") then char.Humanoid.Jump = true end
                    local root = char:FindFirstChild("HumanoidRootPart")
                    if root then root.CFrame = root.CFrame * CFrame.Angles(0, math.rad(15), 0) end
                    UseSelectedSkill()
                end
            end)
        end
    end)
end
StartAntiDisconnect()

