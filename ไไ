local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")

-- =============================================
-- สร้าง GUI เล็กๆ ด้านซ้าย
-- =============================================
local function CreateSimpleGUI()
    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "AutoFarmGUI"
    ScreenGui.ResetOnSpawn = false
    ScreenGui.IgnoreGuiInset = true
    ScreenGui.Parent = player:WaitForChild("PlayerGui")

    -- Main Frame (ด้านซ้าย ลอยเล็กๆ)
    local MainFrame = Instance.new("Frame")
    MainFrame.Name = "MainFrame"
    MainFrame.Size = UDim2.new(0, 180, 0, 220)
    MainFrame.Position = UDim2.new(0, 15, 0.3, 0)
    MainFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    MainFrame.BorderSizePixel = 0
    MainFrame.BackgroundTransparency = 0.05
    MainFrame.Parent = ScreenGui

    -- มุมโค้ง
    local UICorner = Instance.new("UICorner")
    UICorner.CornerRadius = UDim.new(0, 8)
    UICorner.Parent = MainFrame

    -- Title
    local Title = Instance.new("TextLabel")
    Title.Size = UDim2.new(1, 0, 0, 35)
    Title.BackgroundTransparency = 1
    Title.Text = "Auto Farm"
    Title.TextColor3 = Color3.fromRGB(255, 255, 255)
    Title.TextSize = 16
    Title.Font = Enum.Font.GothamBold
    Title.Parent = MainFrame

    local TitleCorner = Instance.new("UICorner")
    TitleCorner.CornerRadius = UDim.new(0, 8)
    TitleCorner.Parent = Title

    -- ปุ่มเปิด/ปิด Auto Farm
    local ToggleButton = Instance.new("TextButton")
    ToggleButton.Name = "ToggleFarm"
    ToggleButton.Size = UDim2.new(0.9, 0, 0, 40)
    ToggleButton.Position = UDim2.new(0.05, 0, 0, 50)
    ToggleButton.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    ToggleButton.Text = _G.AutoFarmEnabled and "ปิด Auto Farm" or "เปิด Auto Farm"
    ToggleButton.TextColor3 = Color3.fromRGB(255, 255, 255)
    ToggleButton.TextSize = 14
    ToggleButton.Font = Enum.Font.GothamSemibold
    ToggleButton.Parent = MainFrame

    local ToggleCorner = Instance.new("UICorner")
    ToggleCorner.CornerRadius = UDim.new(0, 6)
    ToggleCorner.Parent = ToggleButton

    -- ปุ่มเปิด/ปิด พื้นหลังสีดำ (ลดการกินอรม)
    local BlackBGButton = Instance.new("TextButton")
    BlackBGButton.Name = "BlackBG"
    BlackBGButton.Size = UDim2.new(0.9, 0, 0, 40)
    BlackBGButton.Position = UDim2.new(0.05, 0, 0, 100)
    BlackBGButton.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    BlackBGButton.Text = "พื้นหลังดำ: เปิด"
    BlackBGButton.TextColor3 = Color3.fromRGB(255, 255, 255)
    BlackBGButton.TextSize = 14
    BlackBGButton.Font = Enum.Font.GothamSemibold
    BlackBGButton.Parent = MainFrame

    local BlackCorner = Instance.new("UICorner")
    BlackCorner.CornerRadius = UDim.new(0, 6)
    BlackCorner.Parent = BlackBGButton

    -- ปุ่ม Discord
    local DiscordButton = Instance.new("TextButton")
    DiscordButton.Name = "Discord"
    DiscordButton.Size = UDim2.new(0.9, 0, 0, 40)
    DiscordButton.Position = UDim2.new(0.05, 0, 0, 150)
    DiscordButton.BackgroundColor3 = Color3.fromRGB(88, 101, 242) -- สี Discord
    DiscordButton.Text = "เข้าร่วม Discord"
    DiscordButton.TextColor3 = Color3.fromRGB(255, 255, 255)
    DiscordButton.TextSize = 14
    DiscordButton.Font = Enum.Font.GothamSemibold
    DiscordButton.Parent = MainFrame

    local DiscordCorner = Instance.new("UICorner")
    DiscordCorner.CornerRadius = UDim.new(0, 6)
    DiscordCorner.Parent = DiscordButton

    -- ทำให้ GUI ลากได้
    local dragging = false
    local dragInput
    local dragStart
    local startPos

    local function update(input)
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end

    MainFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = MainFrame.Position

            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)

    MainFrame.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and input == dragInput then
            update(input)
        end
    end)

    -- ฟังก์ชัน Toggle Auto Farm
    local function ToggleAutoFarm()
        _G.AutoFarmEnabled = not _G.AutoFarmEnabled
        ToggleButton.Text = _G.AutoFarmEnabled and "ปิด Auto Farm" or "เปิด Auto Farm"
        ToggleButton.BackgroundColor3 = _G.AutoFarmEnabled and Color3.fromRGB(0, 170, 0) or Color3.fromRGB(40, 40, 40)
        print("Auto Farm ตอนนี้: " .. (_G.AutoFarmEnabled and "เปิด" or "ปิด"))
    end

    ToggleButton.MouseButton1Click:Connect(ToggleAutoFarm)

    -- ฟังก์ชันพื้นหลังดำ (ลดการกินอรม โดยการทำให้ Frame มืดขึ้น)
    local blackBGEnabled = true
    local function ToggleBlackBG()
        blackBGEnabled = not blackBGEnabled
        local targetTransparency = blackBGEnabled and 0.05 or 0.4
        local tween = TweenService:Create(MainFrame, TweenInfo.new(0.3), {BackgroundTransparency = targetTransparency})
        tween:Play()
        BlackBGButton.Text = "พื้นหลังดำ: " .. (blackBGEnabled and "เปิด" or "ปิด")
        print("พื้นหลังดำ: " .. (blackBGEnabled and "เปิด" or "ปิด"))
    end

    BlackBGButton.MouseButton1Click:Connect(ToggleBlackBG)

    -- ปุ่ม Discord (เปลี่ยนลิงก์ตรงนี้ได้)
    DiscordButton.MouseButton1Click:Connect(function()
        -- ใส่ลิงก์ Discord ที่ต้องการที่นี่
        setclipboard("https://discord.gg/yourlink") -- หรือใช้ syn.request / request ถ้ามี executor
        print("คัดลอกลิงก์ Discord แล้ว! วางในเบราว์เซอร์")
        -- ถ้าต้องการเปิดลิงก์อัตโนมัติ (บาง executor รองรับ)
        -- pcall(function() game:GetService("StarterGui"):SetCore("SendNotification", {Title = "Discord", Text = "กำลังเปิดลิงก์...", Duration = 3}) end)
    end)

    -- Hover Effect
    local function AddHoverEffect(btn)
        btn.MouseEnter:Connect(function()
            TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = btn.BackgroundColor3:lerp(Color3.fromRGB(255,255,255), 0.1)}):Play()
        end)
        btn.MouseLeave:Connect(function()
            if btn.Name == "ToggleFarm" then
                btn.BackgroundColor3 = _G.AutoFarmEnabled and Color3.fromRGB(0, 170, 0) or Color3.fromRGB(40, 40, 40)
            elseif btn.Name == "BlackBG" then
                btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
            elseif btn.Name == "Discord" then
                btn.BackgroundColor3 = Color3.fromRGB(88, 101, 242)
            end
        end)
    end

    AddHoverEffect(ToggleButton)
    AddHoverEffect(BlackBGButton)
    AddHoverEffect(DiscordButton)

    print("✅ GUI โหลดเสร็จแล้ว (ด้านซ้าย)")
    return ScreenGui
end

CreateSimpleGUI()

-- =============================================
-- ฟังก์ชันร่วม
-- =============================================
local function EquipSelectedWeapon()
    local char = player.Character
    if not char then return end
    local tool = player.Backpack:FindFirstChild(weaponName)
    if tool and not char:FindFirstChild(weaponName) then
        char.Humanoid:EquipTool(tool)
    end
end

local function UseSelectedSkill()
    pcall(function()
        ReplicatedStorage.AbilitySystem.Remotes.RequestAbility:FireServer(skillNumber)
    end)
end

-- =============================================
-- ระบบกันหลุด
-- =============================================
local function StartAntiDisconnect()
    if not _G.AntiDisconnect then return end
    task.spawn(function()
        while true do
            task.wait(19 * 60)
            if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                local root = player.Character.HumanoidRootPart
                pcall(function()
                    if player.Character:FindFirstChild("Humanoid") then
                        player.Character.Humanoid.Jump = true
                    end
                    root.CFrame = root.CFrame * CFrame.Angles(0, math.rad(15), 0)
                    UseSelectedSkill()
                end)
            end
        end
    end)
end
StartAntiDisconnect()

-- =============================================
-- ระบบล่าบอส (แก้ไม่หยุดฟาร์มปกติ)
-- =============================================
local bossesConfig = {
    {boss = "AizenBoss", island = "HollowIsland"},
    {boss = "GojoBoss", island = "Shibuya"},
    {boss = "JinwooBoss", island = "Sailor"},
    {boss = "StrongestShinobiBoss", island = "Ninja"},
    {boss = "SukunaBoss", island = "Shibuya"},
    {boss = "YujiBoss", island = "Shibuya"},
    {boss = "YamatoBoss", island = "Judgement"},
}

local currentFloatBV = nil
local function ClearFloat()
    if currentFloatBV then
        currentFloatBV:Destroy()
        currentFloatBV = nil
    end
    local hum = player.Character and player.Character:FindFirstChild("Humanoid")
    if hum then
        hum.PlatformStand = false
    end
end

local function FloatToBossFixed(bossPos)
    ClearFloat()
    local char = player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
   
    local root = char.HumanoidRootPart
    local hum = char:FindFirstChild("Humanoid")
   
    root.CFrame = CFrame.new(bossPos.X, bossPos.Y + 13, bossPos.Z) * CFrame.Angles(0, root.CFrame.Y, 0)
   
    if hum then hum.PlatformStand = true end
   
    currentFloatBV = Instance.new("BodyVelocity")
    currentFloatBV.MaxForce = Vector3.new(1e5, 1e5, 1e5)
    currentFloatBV.Velocity = Vector3.new(0, 0, 0)
    currentFloatBV.Parent = root
   
    print("🪂 ลอยคงที่ +13 ที่บอส")
end

local function TeleportToIsland(islandName)
    pcall(function()
        ReplicatedStorage.Remotes.TeleportToPortal:FireServer(islandName)
    end)
end

local function CheckAndHuntBoss()
    if _G.BossHunting then return end -- ป้องกันซ้อนกัน
   
    local npcs = workspace:FindFirstChild("NPCs")
    if not npcs then return end
   
    for _, config in ipairs(bossesConfig) do
        local boss = npcs:FindFirstChild(config.boss)
        if boss and boss:FindFirstChild("HumanoidRootPart") then
            _G.BossHunting = true
            print("🔥 พบบอส: " .. config.boss .. " → หยุดฟาร์มปกติแล้วล่า!")
           
            TeleportToIsland(config.island)
            task.wait(0.5)
           
            local updatedBoss = npcs:FindFirstChild(config.boss)
            if updatedBoss and updatedBoss:FindFirstChild("HumanoidRootPart") then
                FloatToBossFixed(updatedBoss.HumanoidRootPart.Position)
                EquipSelectedWeapon()
                task.wait(0.3)
                UseSelectedSkill()
                task.wait(0.1)
               
                -- วนกดสกิลขณะล่าบอส (ประมาณ 8 วินาที)
                for i = 1, 10 do
                    if not npcs:FindFirstChild(config.boss) then break end
                    UseSelectedSkill()
                    task.wait(0.1)
                end
            end
           
            print("✅ ล่าบอสเสร็จ กลับไปฟาร์มปกติ")
            _G.BossHunting = false
            ClearFloat()
            return
        end
    end
end

-- เริ่มระบบล่าบอส
task.spawn(function()
    while true do
        CheckAndHuntBoss()
        task.wait(0.2)
    end
end)

-- =============================================
-- V1 CODE (เพิ่มการตรวจ _G.BossHunting และ _G.AutoFarmEnabled)
-- =============================================
local function RunV1()
    print("✅ เริ่มรัน V1")
    local root = player.Character:WaitForChild("HumanoidRootPart")
    local floatConnection = nil
   
    local function StartFloating()
        if floatConnection then return end
        local hum = player.Character:FindFirstChild("Humanoid")
        if hum then hum.PlatformStand = true end
       
        floatConnection = RunService.Heartbeat:Connect(function()
            if root and root.Parent and not _G.BossHunting then
                root.Velocity = Vector3.new(0,0,0)
                root.AssemblyLinearVelocity = Vector3.new(0,0,0)
                root.AssemblyAngularVelocity = Vector3.new(0,0,0)
                local p = root.Position
                root.CFrame = CFrame.new(p.X, p.Y, p.Z) * root.CFrame.Rotation
            end
        end)
    end
   
    local function TeleportAndFloat(cf)
        if _G.BossHunting or not _G.AutoFarmEnabled then return end
        root.CFrame = cf + Vector3.new(0, 12, 0)
        task.wait(0.2)
        StartFloating()
    end
   
    local function RemoveIslands()
        local islands = {"JudgementIsland","LawlessIsland","NinjaIsland","SoulDominionIsland","TowerIsland","AcademyIsland","HollowIsland","ShinjukuIsland","BossIsland","DesertIsland","JungleIsland","SailorIsland","SlimeIsland","SnowIsland","StarterIsland"}
        for _, v in ipairs(islands) do
            if workspace:FindFirstChild(v) then workspace[v]:Destroy() end
        end
    end
   
    local function BuyAllMerchantItems()
        local merchant = ReplicatedStorage.Remotes.MerchantRemotes.PurchaseMerchantItem
        local items = {{"Dungeon Key",999},{"Boss Key",999},{"Haki Color Reroll",999},{"Race Reroll",999},{"Rush Key",999},{"Passive Shard",999},{"Trait Reroll",999},{"Clan Reroll",999}}
        for _, item in ipairs(items) do
            pcall(function() merchant:InvokeServer(unpack(item)) end)
            task.wait(0.12)
        end
    end
   
    local portals = {
        {name = "Ninja", pos = CFrame.new(-1875.734375, 8.514030, -732.247070)},
        {name = "Lawless", pos = CFrame.new(58.674271, 0.578746, 1825.821777)},
        {name = "Judgement", pos = CFrame.new(-1268.837280, 1.163063, -1184.665771)},
        {name = "Academy", pos = CFrame.new(1059.421997, 1.463216, 1271.781860)},
        {name = "Slime", pos = CFrame.new(-1121.603027, 13.918226, 371.301483)},
        {name = "Shinjuku", pos = CFrame.new(-7.679499, 1.898112, -1842.801514)},
    }
   
    while _G.AutoFarmVersion == "V1" do
        if _G.AutoFarmEnabled and not _G.BossHunting then
            EquipSelectedWeapon()
            RemoveIslands()
            BuyAllMerchantItems()
           
            for _, portal in ipairs(portals) do
                if not _G.AutoFarmEnabled or _G.BossHunting then break end
                EquipSelectedWeapon()
                RemoveIslands()
                ReplicatedStorage.Remotes.TeleportToPortal:FireServer(portal.name)
                task.wait(0.2)
                TeleportAndFloat(portal.pos)
                task.wait(0.2)
                UseSelectedSkill()
                task.wait(0.1)
            end
            print("✅ ครบ 1 รอบ V1 | รอรอบใหม่")
        end
        task.wait(0.5)
    end
end

-- =============================================
-- V2 CODE (เพิ่มการตรวจ _G.BossHunting และ _G.AutoFarmEnabled)
-- =============================================
local function RunV2()
    print("✅ เริ่มรัน V2")
   
    local maps = {"JudgementIsland","LawlessIsland","NinjaIsland","SoulDominionIsland","TowerIsland","AcademyIsland","HollowIsland","ShinjukuIsland","BossIsland","DesertIsland","JungleIsland","SailorIsland","SlimeIsland","SnowIsland","StarterIsland"}
    for _,v in pairs(maps) do
        if workspace:FindFirstChild(v) then workspace[v]:Destroy() end
    end
   
    task.spawn(function()
        while _G.AutoFarmVersion == "V2" do
            if _G.AutoFarmEnabled and not _G.BossHunting then
                local buyList = {{"Dungeon Key",999},{"Boss Key",999},{"Haki Color Reroll",999},{"Race Reroll",999},{"Rush Key",999},{"Passive Shard",999},{"Trait Reroll",999},{"Clan Reroll",999}}
                for _,v in pairs(buyList) do
                    pcall(function() ReplicatedStorage.Remotes.MerchantRemotes.PurchaseMerchantItem:InvokeServer(v[1], v[2]) end)
                    task.wait(0.2)
                end
            end
            task.wait(1)
        end
    end)
   
    local data = {
        {"Ninja","QuestNPC18",Vector3.new(-1875.734375,18.51403,-732.24707)},
        {"Lawless","QuestNPC19",Vector3.new(58.674271,10.578746,1825.821777)},
        {"Judgement","QuestNPC16",Vector3.new(-1268.83728,11.163063,-1184.665771)},
        {"Academy","QuestNPC15",Vector3.new(1059.421997,11.463216,1271.78186)},
        {"Slime","QuestNPC14",Vector3.new(-1121.603027,23.918226,371.301483)},
    }
    local shinjuku1 = Vector3.new(-7.679499,11.898112,-1842.801514)
    local shinjuku2 = Vector3.new(658.236511,11.883463,-1688.614136)
   
    local floatBV
    local function startFloat()
        local char = player.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        if hrp then
            if floatBV then floatBV:Destroy() end
            floatBV = Instance.new("BodyVelocity")
            floatBV.MaxForce = Vector3.new(1e9,1e9,1e9)
            floatBV.Velocity = Vector3.new(0,0,0)
            floatBV.Parent = hrp
        end
    end
    local function tp(pos)
        if _G.BossHunting or not _G.AutoFarmEnabled then return end
        local char = player.Character
        if char and char:FindFirstChild("HumanoidRootPart") then
            char:PivotTo(CFrame.new(pos))
            startFloat()
        end
    end
    local function island(n)
        if _G.BossHunting or not _G.AutoFarmEnabled then return end
        ReplicatedStorage.Remotes.TeleportToPortal:FireServer(n)
    end
    local function quest(q)
        if _G.BossHunting or not _G.AutoFarmEnabled then return end
        ReplicatedStorage.RemoteEvents.QuestAccept:FireServer(q)
    end
   
    while _G.AutoFarmVersion == "V2" do
        if _G.AutoFarmEnabled and not _G.BossHunting then
            for _,v in pairs(data) do
                if not _G.AutoFarmEnabled or _G.BossHunting then break end
                quest(v[2]); task.wait(0.25)
                island(v[1]); task.wait(0.7)
                tp(v[3])
                EquipSelectedWeapon(); task.wait(0.25)
                UseSelectedSkill(); task.wait(1.2)
            end
            -- Shinjuku
            if _G.AutoFarmEnabled and not _G.BossHunting then
                quest("QuestNPC13"); task.wait(0.25); island("Shinjuku"); task.wait(0.7); tp(shinjuku1); EquipSelectedWeapon(); task.wait(0.25); UseSelectedSkill(); task.wait(1.2)
                quest("QuestNPC12"); task.wait(0.25); island("Shinjuku"); task.wait(0.7); tp(shinjuku2); EquipSelectedWeapon(); task.wait(0.25); UseSelectedSkill(); task.wait(1.2)
            end
        end
        task.wait(0.5)
    end
end

-- =============================================
-- เริ่มรัน
-- =============================================
if _G.AutoFarmVersion == "V1" then
    RunV1()
elseif _G.AutoFarmVersion == "V2" then
    RunV2()
end
