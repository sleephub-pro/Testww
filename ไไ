    local function MakeBtn(text, yPos, bgColor, icon)
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(0, 166, 0, 36)
        btn.Position = UDim2.new(0, 12, 0, yPos)
        btn.BackgroundColor3 = bgColor
        btn.Text = (icon and (icon .. "  ") or "") .. text
        btn.TextColor3 = C.Text
        btn.TextSize = 13
        btn.Font = Enum.Font.GothamSemibold
        btn.AutoButtonColor = false
        btn.ZIndex = 4
        btn.Parent = MainFrame
        local corner = Instance.new("UICorner", btn)
        corner.CornerRadius = UDim.new(0, 7)
        local stroke = Instance.new("UIStroke", btn)
        stroke.Color = Color3.fromRGB(255,255,255)
        stroke.Transparency = 0.9
        stroke.Thickness = 1
        btn.MouseEnter:Connect(function()
            TweenService:Create(btn, TweenInfo.new(0.18, Enum.EasingStyle.Quad), {BackgroundColor3 = bgColor:lerp(Color3.fromRGB(255,255,255), 0.08)}):Play()
            TweenService:Create(stroke, TweenInfo.new(0.18), {Transparency = 0.7}):Play()
        end)
        btn.MouseLeave:Connect(function()
            TweenService:Create(btn, TweenInfo.new(0.18, Enum.EasingStyle.Quad), {BackgroundColor3 = bgColor}):Play()
            TweenService:Create(stroke, TweenInfo.new(0.18), {Transparency = 0.9}):Play()
        end)
        btn.MouseButton1Down:Connect(function()
            TweenService:Create(btn, TweenInfo.new(0.08), {Size = UDim2.new(0, 160, 0, 34)}):Play()
            btn.Position = UDim2.new(0, 15, 0, yPos + 1)
        end)
        btn.MouseButton1Up:Connect(function()
            TweenService:Create(btn, TweenInfo.new(0.1), {Size = UDim2.new(0, 166, 0, 36)}):Play()
            btn.Position = UDim2.new(0, 12, 0, yPos)
        end)
        return btn, stroke
    end

