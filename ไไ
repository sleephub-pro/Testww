-- =============================================
-- AUTO FARM V1 + V2 + เลือกอาวุธ + กันหลุด + Boss Priority (ลอยไปหาบอส)
-- =============================================
if not _G.AutoFarmVersion then _G.AutoFarmVersion = "V1" end
if not _G.SelectedWeapon or (_G.SelectedWeapon ~= 1 and _G.SelectedWeapon ~= 2) then
    _G.SelectedWeapon = 2
end
if _G.AntiDisconnect == nil then _G.AntiDisconnect = true end

local weaponName = _G.SelectedWeapon == 1 and "Soul Reaper" or "Demon King"
local skillNumber = _G.SelectedWeapon == 1 and 2 or 1

print("🚀 Auto Farm Version:", _G.AutoFarmVersion)
print("🔫 อาวุธ:", weaponName, "| สกิล:", skillNumber)
print("🛡️ ระบบกันหลุด:", _G.AntiDisconnect and "เปิด (ทุก 20 นาที)" or "ปิด")

local player = game:GetService("Players").LocalPlayer
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace = game:GetService("Workspace")
local RunService = game:GetService("RunService")

-- =============================================
-- ฟังก์ชันร่วม (เหมือนเดิม)
-- =============================================
local function EquipSelectedWeapon()
    local char = player.Character
    if not char then return end
    local tool = player.Backpack:FindFirstChild(weaponName)
    if tool and not char:FindFirstChild(weaponName) then
        char.Humanoid:EquipTool(tool)
    end
end

local function UseSelectedSkill()
    pcall(function()
        ReplicatedStorage.AbilitySystem.Remotes.RequestAbility:FireServer(skillNumber)
    end)
end

-- ระบบกันหลุด (เหมือนเดิม)
local function StartAntiDisconnect()
    if not _G.AntiDisconnect then return end
    task.spawn(function()
        while true do
            task.wait(20 * 60)
            if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                local root = player.Character.HumanoidRootPart
                local hum = player.Character:FindFirstChild("Humanoid")
                pcall(function()
                    if hum then hum.Jump = true end
                    root.CFrame = root.CFrame * CFrame.Angles(0, math.rad(15), 0)
                    UseSelectedSkill()
                end)
                print("🛡️ ระบบกันหลุดทำงาน (" .. os.date("%H:%M:%S") .. ")")
            end
        end
    end)
end
StartAntiDisconnect()

-- =============================================
-- ระบบลอยค้าง (เหมือนเดิม)
-- =============================================
local floatConnection = nil
local bodyVelocity = nil

local function StartFloating(height)
    local char = player.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    if floatConnection then floatConnection:Disconnect() end
    if bodyVelocity then bodyVelocity:Destroy() end

    bodyVelocity = Instance.new("BodyVelocity")
    bodyVelocity.Name = "AutoFarmFloat"
    bodyVelocity.MaxForce = Vector3.new(1e5, 1e5, 1e5)
    bodyVelocity.Velocity = Vector3.new(0, 0, 0)
    bodyVelocity.Parent = root

    char.Humanoid.PlatformStand = true

    floatConnection = RunService.Heartbeat:Connect(function()
        if root and root.Parent then
            local currentPos = root.Position
            root.CFrame = CFrame.new(currentPos.X, currentPos.Y, currentPos.Z) * root.CFrame.Rotation
            if math.abs(currentPos.Y - height) > 2 then
                root.Velocity = Vector3.new(0, (height - currentPos.Y) * 15, 0)
            else
                root.Velocity = Vector3.new(0, 0, 0)
            end
        end
    end)
end

local function StopFloating()
    if floatConnection then
        floatConnection:Disconnect()
        floatConnection = nil
    end
    if bodyVelocity then
        bodyVelocity:Destroy()
        bodyVelocity = nil
    end
    if player.Character and player.Character:FindFirstChild("Humanoid") then
        player.Character.Humanoid.PlatformStand = false
    end
end

-- =============================================
-- ระบบลอยไปหาบอส (ใหม่ตามที่ขอ)
-- =============================================
local bossData = {
    AizenBoss = {targetHeight = 13},
    GojoBoss = {targetHeight = 13},
    JinwooBoss = {targetHeight = 13},
    StrongestShinobiBoss = {targetHeight = 13},
    SukunaBoss = {targetHeight = 13},
    YujiBoss = {targetHeight = 13},
    YamatoBoss = {targetHeight = 13},
}

local function FlyToBoss(bossName)
    local boss = Workspace.NPCs:FindFirstChild(bossName)
    if not boss then return false end

    print("🟥 พบบอส: " .. bossName .. " | กำลังลอยไปหา...")

    StopFloating()

    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return false end

    -- เริ่มลอยและเคลื่อนที่ไปหาบอสแบบ smooth
    local moveConnection
    moveConnection = RunService.Heartbeat:Connect(function()
        if not Workspace.NPCs:FindFirstChild(bossName) then
            if moveConnection then moveConnection:Disconnect() end
            return
        end

        local bossPos = boss:FindFirstChild("HumanoidRootPart") or boss.PrimaryPart
        if bossPos and root then
            local targetPos = bossPos.Position + Vector3.new(0, 13, 0)  -- ลอยเหนือบอส 13 หน่วย
            local currentPos = root.Position

            -- ลอยไปหาแบบ smooth (lerp)
            local newPos = currentPos:Lerp(targetPos, 0.08)  -- ปรับ 0.08 ได้ถ้าต้องการเร็ว/ช้า
            root.CFrame = CFrame.new(newPos) * root.CFrame.Rotation

            -- รักษาความสูง
            StartFloating(targetPos.Y)
        end
    end)

    EquipSelectedWeapon()
    task.wait(0.5)
    UseSelectedSkill()

    -- รอจนกว่าบอสจะหายไป
    while Workspace.NPCs:FindFirstChild(bossName) and _G.AutoFarmVersion do
        task.wait(0.8)
        EquipSelectedWeapon()
        UseSelectedSkill()
    end

    if moveConnection then moveConnection:Disconnect() end
    print("✅ บอส " .. bossName .. " หายไปแล้ว | กลับไปฟาร์มปกติ")
    StopFloating()
    task.wait(1)
    return true
end

local function HandleBoss()
    for bossName, _ in pairs(bossData) do
        if Workspace.NPCs:FindFirstChild(bossName) then
            return FlyToBoss(bossName)
        end
    end
    return false
end

-- =============================================
-- V1 CODE (เหมือนเดิม ยกเว้นเรียก HandleBoss)
-- =============================================
local function RunV1()
    print("✅ เริ่มรัน V1 + ลอยไปหาบอส")
    
    local portals = {
        {name = "Ninja", pos = CFrame.new(-1875.734375, 8.514030, -732.247070)},
        {name = "Lawless", pos = CFrame.new(58.674271, 0.578746, 1825.821777)},
        {name = "Judgement", pos = CFrame.new(-1268.837280, 1.163063, -1184.665771)},
        {name = "Academy", pos = CFrame.new(1059.421997, 1.463216, 1271.781860)},
        {name = "Slime", pos = CFrame.new(-1121.603027, 13.918226, 371.301483)},
        {name = "Shinjuku", pos = CFrame.new(-7.679499, 1.898112, -1842.801514)},
    }

    while _G.AutoFarmVersion == "V1" do
        if HandleBoss() then
            continue
        end

        EquipSelectedWeapon()

        for _, portal in ipairs(portals) do
            if HandleBoss() then break end
            
            EquipSelectedWeapon()
            ReplicatedStorage.Remotes.TeleportToPortal:FireServer(portal.name)
            task.wait(0.8)
            
            local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            if root then
                root.CFrame = portal.pos + Vector3.new(0, 13, 0)
                task.wait(0.3)
                StartFloating(portal.pos.Position.Y + 13)
            end
            
            task.wait(0.3)
            UseSelectedSkill()
            task.wait(0.8)
        end
        
        print("✅ ครบ 1 รอบ V1 | รอรอบใหม่")
        task.wait(1)
    end
end

