            end
            
            EquipSelectedWeapon()
            task.wait(0.3)
            UseSelectedSkill()
            task.wait(1.2)
        end

        -- Shinjuku (เหมือนเดิม)
        if not HandleBoss() then
            pcall(function() ReplicatedStorage.RemoteEvents.QuestAccept:FireServer("QuestNPC13") end)
            task.wait(0.25)
            ReplicatedStorage.Remotes.TeleportToPortal:FireServer("Shinjuku")
            task.wait(0.7)
            local char = player.Character
            if char and char:FindFirstChild("HumanoidRootPart") then
                char:PivotTo(CFrame.new(-7.679499,11.898112,-1842.801514) + Vector3.new(0,13,0))
                StartFloating(11.898112 + 13)
            end
            EquipSelectedWeapon(); task.wait(0.3); UseSelectedSkill(); task.wait(1.2)
        end

        if not HandleBoss() then
            pcall(function() ReplicatedStorage.RemoteEvents.QuestAccept:FireServer("QuestNPC12") end)
            task.wait(0.25)
            ReplicatedStorage.Remotes.TeleportToPortal:FireServer("Shinjuku")
            task.wait(0.7)
            local char = player.Character
            if char and char:FindFirstChild("HumanoidRootPart") then
                char:PivotTo(CFrame.new(658.236511,11.883463,-1688.614136) + Vector3.new(0,13,0))
                StartFloating(11.883463 + 13)
            end
            EquipSelectedWeapon(); task.wait(0.3); UseSelectedSkill(); task.wait(1.2)
        end

        task.wait(1)
    end
end

